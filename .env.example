# =============================
# Next.js + Sanity + Neon setup
# Copy this file to `.env.local`
# =============================

# --- Sanity ---
# Get these from sanity.io/manage > your project
NEXT_PUBLIC_SANITY_PROJECT_ID=your_project_id
NEXT_PUBLIC_SANITY_DATASET=production

# Optional (if you later need private read/write from server):
# SANITY_API_READ_TOKEN=

# --- Neon (contact form storage) ---
# Server-only env used by app/api/contact/route.ts via lib/neon.ts
# Use the standard Neon connection string from Dashboard > Connection Details
DATABASE_URL=postgresql://<user>:<password>@<host>/<database>?sslmode=require

# --- Cloudflare Turnstile (anti-spam) ---
# Create a widget in Cloudflare Dashboard > Turnstile
NEXT_PUBLIC_TURNSTILE_SITE_KEY=<your_turnstile_site_key>
TURNSTILE_SECRET_KEY=<your_turnstile_secret_key>

# --- Resend (email delivery) ---
# Verify a sending domain in Resend for production use.
# For early testing, Resend may allow onboarding@resend.dev with account restrictions.
RESEND_API_KEY=<your_resend_api_key>
RESEND_FROM_EMAIL="Jennifer Atelier <onboarding@resend.dev>"
CONTACT_TO_EMAIL=jenniferatelier@gmail.com
